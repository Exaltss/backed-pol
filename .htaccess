# 1. Konfigurasi PHP (Upload Limit & Resource)
# Letakkan di paling atas agar server memproses limitasi ini lebih dulu
php_value upload_max_filesize 100M
php_value post_max_size 100M
php_value max_execution_time 300
php_value max_input_time 300
php_value memory_limit 256M

<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # 2. Keamanan: Lindungi file sensitif
    <Files .env>
        Order allow,deny
        Deny from all
    </Files>
    
    # Blokir akses ke file sistem dan folder inti
    RewriteRule ^(.env|artisan|composer.json|composer.lock|package.json|phpunit.xml) - [F,L]
    RewriteRule ^(app|bootstrap|config|database|resources|routes|storage|tests|vendor)($|/) - [F,L]

    # 3. Handle Authorization Header (Penting untuk API/Login)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # 4. Redirect Trailing Slashes (Menghilangkan tanda / di akhir URL agar SEO friendly)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # 5. Jembatan ke folder /public
    # Mengalihkan trafik ke public/index.php jika file asli tidak ditemukan
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]

    # Jika file tidak ada di public, arahkan ke index.php
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php82” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php82 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit